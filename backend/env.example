# PaddleOCR API 配置（PDF OCR 解析，需在 aistudio 获取 access token）
# https://aistudio.baidu.com/paddleocr
PADDLEOCR_TOKEN=xxxxxx
# PADDLEOCR_JOB_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs  # 可选，默认如上
# PADDLEOCR_MODEL=PaddleOCR-CL-1.5  # 可选，默认 PaddleOCR-CL-1.5

# SiliconFlow 配置（LLM：简历抽取、JD 解析、智能对话）
# https://cloud.siliconflow.cn/me/account/ak
SILICONFLOW_API_KEY=xxxxxx
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1  # 可选
# SILICONFLOW_CHAT_MODEL=Pro/deepseek-ai/DeepSeek-V3.2  # 可选
# SILICONFLOW_TEMPERATURE=0.1   # 抽取用，可选
# SILICONFLOW_MAX_TOKENS=2000   # 可选